<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon mirrors the iOS demo (white background + OpenBMB blue mark).
  background    : solid white (matches iOS AppIcon canvas)
  foreground    : per-density bitmap generated from MiniCPM-V-demo/Assets.xcassets/AppIcon.appiconset/AppIcon.png
  monochrome    : reuses the foreground silhouette so themed icons (Android 13+) still recognise the mark
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
    <monochrome android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
