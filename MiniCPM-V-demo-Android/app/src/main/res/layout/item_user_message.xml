<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="end"
    android:paddingHorizontal="12dp"
    android:paddingVertical="6dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/fl_user_image_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/iv_user_image"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/image_desc" />

                <!-- Play badge overlay; only visible for video messages.
                     Mirrors iOS MBImageTableViewCell's video overlay so
                     the user can tell at a glance "this was a video, the
                     model saw N sampled frames". -->
                <ImageView
                    android:id="@+id/iv_video_play_badge"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:background="@drawable/bg_video_play_badge"
                    android:padding="10dp"
                    android:src="@drawable/ic_play_arrow"
                    android:contentDescription="@string/image_desc" />
            </FrameLayout>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone"
                android:layout_marginBottom="8dp"
                app:indicatorColor="?attr/colorPrimary"
                app:trackCornerRadius="2dp"
                app:trackThickness="4dp" />

            <TextView
                android:id="@+id/tv_image_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:alpha="0.7"
                android:visibility="gone"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_user_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.2" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
